# Call Notification Hook(s)
run_notification_hooks() {
  if [[ $N_notification_hooks != 0 ]]; then
    local notification_title="${1}"
    local notification_body="${2}"

    # Notification Attachment may not exist
    local notification_attachment="${3:-}"

    # Only run the notification hooks if enabled or in the case of a warning
    if [[ ( "${disable_emails_on_success}" == "no" ) || \
          ( "${disable_emails_on_success}" == "yes" && -n "${notification_attachment}" ) ]]
    then
      log "##############################"
      log "# SnapRAID-DAILY: Notification Hook(s)"
      log "##############################"

      # Loop through all defined hooks
      for ((i=1; i<=N_notification_hooks; i++)); do
        local notification_hook="notification_hook"$i

        # Call the Custom Notification Hook Script if one was given
        if [[ -x "${!notification_hook}" ]]; then
          log " * Calling Notification Hook $i/$N_notification_hooks :" "${!notification_hook}"
          if ! "${!notification_hook}" "${notification_title}" "${notification_body}" "${notification_attachment}"; then
            log " * WARNING: Notification Hook ${notification_hook} returned an error"
          fi
          log ""
        fi
      done
    fi
  fi
}

# Insert File differences into email
include_differences_in_email() {

  # Only do this if include_diff_in_email is set to yes...
  if [[ "${include_diff_in_email}" == "yes" ]]; then
    local diff_changes_log

    # Check if Scrub Only was Set based on Input Options
    if [[ $scrub_only == "yes" ]]; then
      diff_changes_log="${scrub_changes_log}"
    else
      diff_changes_log="${sync_changes_log}"
    fi

    # Only proceed if the file is not empty...
    if [[ -s "${diff_changes_log}" ]]; then

      # Need to get the changes again
      number_equal=$( awk -F ":" '/^summary:equal:/ {print $3}' "${diff_changes_log}")
      number_added=$( awk -F ":" '/^summary:added:/ {print $3}' "${diff_changes_log}")
      number_removed=$( awk -F ":" '/^summary:removed:/ {print $3}' "${diff_changes_log}")
      number_updated=$( awk -F ":" '/^summary:updated:/ {print $3}' "${diff_changes_log}")
      number_moved=$( awk -F ":" '/^summary:moved:/ {print $3}' "${diff_changes_log}")
      number_copied=$( awk -F ":" '/^summary:copied:/ {print $3}' "${diff_changes_log}")
      number_relocated=$( awk -F ":" '/^summary:relocated:/ {print $3}' "${diff_changes_log}")
      number_restored=$( awk -F ":" '/^summary:restored:/ {print $3}' "${diff_changes_log}")

      # Print a Banner and include the changes in the main logfile
      log_to_email ""
      log_to_email "##############################"
      log_to_email "# SnapRAID-DAILY: File Differences"
      log_to_email "##############################"
      if [[ $number_added == 0 && $number_removed == 0 && $number_updated == 0 && $number_moved == 0 && \
            $number_copied == 0 && $number_relocated == 0 && $number_restored == 0 ]]
      then
        log_to_email_time "No Changes since the last sync."
      else
        log_to_email_time "These are the file differences since the last sync."
        log_to_email ""
        log_to_email "Added Files: $number_added"
        if [[ $number_added != 0 ]]; then
          awk '/^scan:add/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Removed Files: $number_removed"
        if [[ $number_removed != 0 ]]; then
          awk '/^scan:remove/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Updated Files: $number_updated"
        if [[ $number_updated != 0 ]]; then
          awk '/^scan:update/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Moved Files: $number_moved"
        if [[ $number_moved != 0 ]]; then
          awk '/^scan:move/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Copied Files: $number_copied"
        if [[ $number_copied != 0 ]]; then
          awk '/^scan:copy/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Relocated Files: $number_relocated"
        if [[ $number_relocated != 0 ]]; then
          awk '/^scan:relocate/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
        log_to_email ""
        log_to_email "Restored Files: $number_restored"
        if [[ $number_restored != 0 ]]; then
          awk '/^scan:restore/ { sub(/^scan:/, ""); print }' "${diff_changes_log}" | tee -a "${main_logfile}"
        fi
      fi
    fi
  fi
}

# Success Notification
notify_of_success() {

  # Call Snapraid Status to Put the Final Array Status into the Email
  snapraid_status_to_email

  # Figure out the subject for the Notification(s)
  if [[ $sync_only == "yes" ]]; then
    if [[ $sync_required == "yes" ]]; then
      success_subject="SnapRAID-DAILY: Sync OK"
    else
      success_subject="SnapRAID-DAILY: Nothing to Sync"
    fi
  elif [[ $scrub_only == "yes" ]]
  then
    if [[ $nothing_to_scrub == "yes" ]]; then
      success_subject="SnapRAID-DAILY: Nothing to Scrub"
    else
      success_subject="SnapRAID-DAILY: Scrub OK"
    fi
  else
    if [[ $sync_required == "no" && $nothing_to_scrub == "yes" ]]; then
      success_subject="SnapRAID-DAILY: Nothing to Sync OR Scrub"
    else
      success_subject="SnapRAID-DAILY: All OK"
    fi
  fi

  # Print Success Banner here
  if [[ "${end_hook_errors}" == "no" ]]; then
    log_to_email "##############################"
    log_to_email "# SnapRAID-DAILY Result: SUCCESS"
    log_to_email "##############################"
  else
    log_to_email "##############################"
    log_to_email "# SnapRAID-DAILY Result: WARNING(S)"
    log_to_email "##############################"
  fi

  # Insert Differences into Email Logfile if Enabled
  include_differences_in_email

  # Send the Success Email
  if [[ "${disable_emails_on_success}" == "no" && "${enable_emails}" == "yes" ]]; then
    send_email "${success_subject}"
  fi

  # Call the Custom Notification Hook Script if one was given
  run_notification_hooks "${success_subject}" "${main_logfile}"
}

# Warning Notification
notify_of_warning() {
  local subject="${1}"
  local attachment="${2:-}"
  local status="${3:-}"

  # Include the output of the status command in the email if required
  if [[ -n "${status}" ]]; then
    snapraid_status_to_email
  fi

  # Print Warning Banner here
  log_to_email "##############################"
  log_to_email "# SnapRAID-DAILY Result: WARNING(S)"
  log_to_email "##############################"

  # Insert Differences into Email Logfile if Enabled
  include_differences_in_email

  # Send Email Notification if Emails are Enabled and include attachment if present
  if [[ $enable_emails == "yes" && -n "${attachment}" ]]; then
    send_email "${subject}" "${attachment}"
  elif [[ $enable_emails == "yes" && -z "${attachment}" ]]; then
    send_email "${subject}"
  fi

  # If Custom Notification Hook are present - Call them here
  if [[ -z "${attachment}" ]]; then
    run_notification_hooks "${subject}" "${main_logfile}"
  else
    run_notification_hooks "${subject}" "${main_logfile}" "${attachment}"
  fi
}

# Send Emails using mutt 
send_email() {
  local email_subject="${1}"

  # Email Attachment may not exist...
  local email_attachment="${2:-}"

  # Add the Hostname as a Signature to the Emails
  if [[ -n "${system_hostname}" ]]; then
    log_to_email "" &>"/dev/null"
    log_to_email "Regards," &>"/dev/null"
    log_to_email "${system_hostname}" &>"/dev/null"
    log ""
  fi

  # Generate mutt args
  mutt_args=( -F "${muttrc_path}" -s "${email_subject}" )
  if [[ -n "${email_attachment:-}" ]]; then
    mutt_args+=( -a "${email_attachment}" -- )
  fi

  # Call mutt to send the email
  log "Emailing ${email_address}..."
  if mutt "${mutt_args[@]}" "${email_address}" < "${main_logfile}"; then
    log "Email Sent Successfully"
    log ""
  else
    log "Problem Sending Email"
    log ""
  fi
}

# Clean Up Log-Files Function
clean_up_logfiles() {
  log "Removing /tmp files..."
  local logfiles=( "${main_logfile}" "${status_command_logfile}" "${scrub_command_logfile}" \
                "${sync_command_logfile}" "${touch_command_logfile}" "${diff_command_logfile}" \
                "${main_logfile_without_diff}" "${sync_changes_log}" "${scrub_changes_log}")
  for file in "${logfiles[@]}"; do
    rm -f -- "${file}" &>"/dev/null"
  done
}

