# Read Config File parameters in - unset all variables 1st
read_config_file() {

  # Find script directory
  script_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

  # Configuration Files are read in the following order of preference
  # 1 - Custom Config file if specified by the -f or --config options
  # 2 - /etc/snapraid-daily.conf
  # 3 - Same directory as script
  # Exit if none of the above are found
  config_file0="${custom_config_file}"
  config_file1="/etc/snapraid-daily.conf"
  config_file2="${script_directory}""/snapraid-daily.conf"
  if [[ -r "${config_file0}" ]]; then
    log "INFO: Using Config File:" "${config_file0}"
    # shellcheck source=./config/snapraid-daily.conf
    source "${config_file0}"
  elif [[ -r "${config_file1}" ]]; then
    log "INFO: Using Config File:" "${config_file1}"
    # shellcheck source=./config/snapraid-daily.conf
    source "${config_file1}"
  elif [[ -r "${config_file2}" ]]; then
    log "INFO: Using Config File:" "${config_file2}"
    # shellcheck source=./config/snapraid-daily.conf
    source "${config_file2}"
  else
    log "WARNING: No config file found/readable in any of the following locations:"
    log "1. Specified with the -f or --config option"
    log "2: /etc/snapraid-daily.conf"
    log "3: snapraid-daily.conf in script directory:" "${script_directory}"
    log ""
    log "All Defaults will be used"
    log "See the manual entry for snapraid-daily.conf(1)"
    log ""
  fi

  # Check Snapraid Config File Path
  if [[ -z "${snapraid_config_file_path}" ]]; then
    if [[ ! -r "/etc/snapraid.conf" ]]; then
      error "snapraid_config_file_path missing in config and default of /etc/snapraid.conf not found/readable - Exiting"
    else 
      log "WARNING: snapraid_config_file_path not defined in config - Using /etc/snapraid.conf"
      snapraid_config_file_path="/etc/snapraid.conf"
    fi
  elif [[ ! -r "${snapraid_config_file_path}" ]]; then
    error "snapraid_config_file_path:" "${snapraid_config_file_path}" "does not exist or is not readable - Exiting"
  fi

  # Check for a Valid muttrc file and email address. If not found, disable the email functionality
  if [[ -z "${muttrc_path}" || ! -r "${muttrc_path}" ]]; then
    log "WARNING: muttrc_path missing in config, not readable, or doesn't exist - No Emails will be sent"
    enable_emails="no"
  elif [[ -z "${email_address}" ]]; then
    log "WARNING: email_address missing from snapraid-daily.conf - No Emails will be sent"
    enable_emails="no"
  else
    enable_emails="yes"
  fi

  # Check for the Deletion Threshold
  if [[ -z "${deletion_threshold}" ]]; then
    log "WARNING: deletion_threshold not defined in snapraid-daily.conf - Using 100 by default"
    deletion_threshold=100
  elif ! is_number "$deletion_threshold"; then
    error "deletion_threshold value" "${deletion_threshold}" "is invalid. It should be a number >=0"
  fi

  # Check Moved Threshold
  if [[ -z "${moved_threshold}" ]]; then
    log "WARNING: moved_threshold not defined in snapraid-daily.conf - Using 100 by default"
    moved_threshold=100
  elif ! is_number "$moved_threshold"; then
    error "moved_threshold value" "${moved_threshold}" "is invalid. It should be a number >=0"
  fi

  # Check Updated Threshold
  if [[ -z "${updated_threshold}" ]]; then
    log "WARNING: updated_threshold not defined in snapraid-daily.conf - Using 100 by default"
    updated_threshold=100
  elif ! is_number "$updated_threshold"; then
    error "updated_threshold value" "${updated_threshold}" "is invalid. It should be a number >=0"
  fi

  # Check for a Scrub Percent. default to 8%, sanity check its between 0 and 100
  if [[ -z "${scrub_percent}" ]]; then
    log "WARNING: scrub_percent is not defined snapraid-daily.conf - Using 8%"
    scrub_percent=8
  elif ! is_valid_scrub_percent_number "$scrub_percent"; then
    error "scrub-percent value:" "$scrub_percent" "is invalid - It should be a number between 0.0 and 100.0 with Up to One Decimal Place - Exiting"
  fi

  # Check for a Scrub Age, default to 21 days, sanity check its not negative
  if [[ -z "${scrub_age}" ]]; then
    log "WARNING: scrub_age is not defined in snapraid-daily.conf - Using 21 days"
    scrub_age=21
  elif ! is_number "$scrub_age"; then
    error "scrub_age value:" "$scrub_age" "is invalid - It should be a number >=0"
  elif [[ $scrub_age -lt 0 ]]; then
    error "scrub_age cannot be a negative number - Exiting"
  fi

  # Check for disable_emails_on_success, default to no. Sanity check it's "yes" or "no"
  if [[ -z "${disable_emails_on_success}" ]]; then
    disable_emails_on_success="no"
  elif [[ "${disable_emails_on_success}" != "yes" && "${disable_emails_on_success}" != "no" ]]; then
    error "Specified invalid disable_emails_on_success in config - It should be either \"yes\" or \"no\""
  elif [[ "${disable_emails_on_success}" == "yes" ]]; then
    log "INFO: Notification Emails & Hook(s) disabled on Success"
  fi

  # Check for include_diff_in_email, default to no. Sanity check it's "yes" or "no"
  if [[ -z "${include_diff_in_email}" ]]; then
    include_diff_in_email="no"
  elif [[ "${include_diff_in_email}" != "yes" && "${include_diff_in_email}" != "no" ]]; then
    error "Specified invalid include_diff_in_email in config file - It should be either \"yes\" or \"no\""
  fi

  # Check for sync_pre_hash, default to yes. Sanity check it's "yes" or "no"
  if [[ -z "${sync_pre_hash}" ]]; then
    sync_pre_hash="yes"
  elif [[ "${sync_pre_hash}" != "yes" && "${sync_pre_hash}" != "no" ]]; then
    error "Specified invalid sync_pre_hash in config file - It should be either \"yes\" or \"no\""
  fi

  # Check for force_zero & if set with input args. Default to no if undefined - exit if invalid
  if [[ "${force_zero_arg}" == "yes" ]]; then
    force_zero="yes"
  elif [[ -z "${force_zero}" ]]; then
    force_zero="no"
  elif [[ "${force_zero}" != "yes" && "${force_zero}" != "no" ]]; then
    error "Specified invalid force_zero in config - It should be either \"yes\" or \"no\""
  fi

  # Check for force_empty & if set with input args. Default to no if undefined - exit if invalid
  if [[ "${force_empty_arg}" == "yes" ]]; then
    force_empty="yes"
  elif [[ -z "${force_empty}" ]]; then
    force_empty="no"
  elif [[ "${force_empty}" != "yes" && "${force_empty}" != "no" ]]; then
    error "Specified invalid force_empty in config file - It should be either \"yes\" or \"no\""
  fi

  # Check for force_uuid & if set with input args. Default to no if undefined - exit if invalid
  if [[ "${force_uuid_arg}" == "yes" ]]; then
    force_uuid="yes"
  elif [[ -z "${force_uuid}" ]]; then
    force_uuid="no"
  elif [[ "${force_uuid}" != "yes" && "${force_uuid}" != "no" ]]; then
    error "Specified invalid force_uuid in config file - It should be either \"yes\" or \"no\""
  fi

  # Check for force_nocopy & if set with input args. Default to no if undefined - exit if invalid
  if [[ "${force_nocopy_arg}" == "yes" ]]; then
    force_nocopy="yes"
  elif [[ -z "${force_nocopy}" ]]; then
    force_nocopy="no"
  elif [[ "${force_nocopy}" != "yes" && "${force_nocopy}" != "no" ]]; then
    error "Specified invalid force_nocopy in config file - It should be either \"yes\" or \"no\""
  fi

  # Check for disable_update_check parameter. If undefined - default it to disabled
  if [[ -z "${disable_update_check}" ]]; then
    disable_update_check="no"
  elif [[ "${disable_update_check}" != "yes" && "${disable_update_check}" != "no" ]]; then
    error "Specified invalid disable_update_check in config file - It should be either \"yes\" or \"no\""
  fi

  # SMART Report (Off by default)
  if [[ -z "${smart_report}" ]]; then
    smart_report="no"
  elif [[ "${smart_report}" != "yes" && "${smart_report}" != "no" ]]; then
    error "Specified invalid smart_report in config file - It should be either \"yes\" or \"no\""
  fi

  # Spin Down Disks (Off by default)
  if [[ -z "${spin_down_disks}" ]]; then
    spin_down_disks="no"
  elif [[ "${spin_down_disks}" != "yes" && "${spin_down_disks}" != "no" ]]; then
    error "Specified invalid spin_down_disks in config file - It should be either \"yes\" or \"no\""
  fi
  
  # Check Start/End/Notfication hooks to see if they are defined
  get_number_of_hooks "start_hook"
  get_number_of_hooks "end_hook"
  get_number_of_hooks "notification_hook"
}

# Check for Update via Github Page if not disabled in the config and if curl is installed
check_for_update() {
  update_available="no"
  if [[ "${disable_update_check}" == "no" ]] && is_installed curl; then
    local_script_version="$(sed 's/\.//g;s/~//;s/beta[0-9]*//' <<<"${version}")"
    if github_version=$(curl --silent --retry 3 "${github_version_file}"); then
      github_script_version="$(sed 's/\.//g;s/~//;s/beta[0-9]*//' <<<"${github_version}")"
      if is_number "${github_script_version}" && [[ "${github_script_version}" -gt "${local_script_version}" ]]; then
        update_available="yes"
      fi
    else
      log "WARNING: Contacting ${github_page} for an update failed..."
    fi
  fi
}

# Sanity Check for Dependencies
check_dependencies() {
  if [[ -n "${snapraid_binary_path}" ]]; then
    if [[ ! -x "${snapraid_binary_path}" ]]; then
      error "SnapRAID Binary Path: ${snapraid_binary_path} in Config File does not exist or is not Executable"
    else
      log "INFO: SnapRAID Binary Path: ${snapraid_binary_path}"
    fi
  else
    if ! is_installed snapraid; then
      error "SnapRAID is not installed or not found in \$PATH"
    else
      snapraid_binary_path="$(command -v snapraid)"
    fi
  fi

  # Check all dependencies - Disable emails if mutt is not installed or in $PATH
  local dependencies=( "grep" "tee" "awk" "sed" "mktemp" "date" "dirname" "readlink" "whoami")
  for cmd in "${dependencies[@]}"; do
    if ! is_installed "${cmd}"; then error "${cmd} not installed or found in \$PATH - Exiting..."; fi
  done
  if ! is_installed mutt; then
    log "WARNING: mutt command not found in \$PATH - No emails will be sent"
    enable_emails="no"
  fi
  log ""
}

# Print a condensed help message for a quick start
