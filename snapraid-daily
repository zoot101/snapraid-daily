#!/usr/bin/env bash
###################################################
# SnapRAID-DAILY
###################################################
# Github Page: https://github.com/zoot101/snapraid-daily
###################################################

# VERSION
version="1.7.2"

###################################################
# VARIABLES
###################################################
max_hooks=5
github_page="https://github.com/zoot101/snapraid-daily"
github_version_file="https://raw.githubusercontent.com/zoot101/snapraid-daily/refs/heads/main/VERSION"

###################################################
# RETURN CODES
###################################################
success_code=0                      # Success
error_code=1                        # All Errors
already_in_use_code=2               # SnapRAID Already in use
files_modified_during_sync_code=3   # Files Modified During Sync
thresholds_exceeded_code=5          # Deletion/Moved Thresholds exceeded

# Modern Error Handling
set -euo pipefail

###################################################
# MAIN FUNCTION
###################################################
main() {

  # Unset All Config Variables
  unset_all_config_variables

  # Parse Input Arguments
  parse_arguments "$@"
  
  # Read & Check Config File, Check for an Update (if enabled) & Check Dependencies
  read_config_file
  check_for_update
  check_dependencies
  
  # Generate Logfiles for Analysis
  generate_logfiles
  
  # Start Email log and print greeting
  print_greeting
 
  # Check the intial status for errors or if touch is needed
  initial_status_check
  
  # Run Start Hook (if given)
  run_start_hooks
 
  # Run Touch if it is required, check for deletion/moved thresholds
  # and then sync the array. Only if the --scrub-only is not selected
  if [[ "${scrub_only}" == "no" ]]; then
    run_touch_if_needed
    check_array_for_changes_and_thresholds
    sync_array
  fi
  
  # Scrub & Check the output for errors if --sync-only is not selected
  if [[ "${sync_only}" == "no" ]]; then
    scrub_array
  fi
  
  # Run End Hook (if given)
  run_end_hooks

  # Generate SMART Report and spin down disks if enabled and running as root or using sudo
  generate_smart_report
  spin_down_hdd_disks

  # Send Final Notification Email if No Errors were detected, clean up
  # /tmp logfiles and exit with success
  notify_of_success
  clean_up_logfiles
  exit $success_code
}

###################################################
# FUNCTIONS
###################################################
# Error Function for Errors that exit immediately
error() {
  log "ERROR:" "$@"
  log ""
  exit $error_code
}

# Function to check if a Variable is a number >= 0
is_number() {
  local number_regex='^[0-9]+$'
  if ! [[ "$1" =~ $number_regex ]]; then
    return 1
  else
    return 0
  fi
}

# Function to check for a valid scrub number
is_valid_scrub_percent_number() {
  local number="$1"

  # Matches: 0.0 to 99.9, 100.0 only
  if [[ "$number" =~ ^(100(\.0)?|([0-9]{1,2}(\.[0-9])?))$ ]]; then
    return 0
  else
    return 1
  fi
}

# Check if a command is available
is_installed() {
  command -v "${1}" &>"/dev/null"
}

# Check content files are writable
check_content_files_exist() {

  # Read the main Configuration file line-by-line
  while IFS= read -r line; do

    # Strip leading whitespace, trailing comment if present & Skip empty lines and comments
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%%#*}"
    if [[ -z "${line}" || "$line" == \#* ]]; then continue; fi
  
    # Only process lines starting with "content"
    if [[ "$line" == content[[:space:]]* ]]; then

      # Remove Content & Trim Leading & Trailing Whitespaces
      content_file="${line#content}"
      content_file="${content_file#"${content_file%%[![:space:]]*}"}"
      content_file="${content_file%"${content_file##*[![:space:]]}"}"

      # Check if the Content File exists & is Writable - if not exit & notify the user.
      # If it does exist, check the ownership and exit if any are not owned by the script user,
      # unless the user has used the -i, --ignore-user option.
      if [[ -w "${content_file}" ]]; then
        if [[ ! -O "${content_file}" && "${ignore_script_user}" == "no" ]]; then
          log_to_email_time "ERROR: SnapRAID Content File: ${content_file} in ${snapraid_config_file_path} is not owned by user: $(whoami)"
          log_to_email_time "Use the -i / --ignore-user option to bypass the ownership check on the SnapRAID Content Files if this is OK"
          log_to_email ""
          notify_of_warning "SnapRAID-DAILY: Content File(s) Error"
          clean_up_logfiles
          exit "$error_code"
        fi
      else
        log_to_email_time "ERROR: SnapRAID Content File: ${content_file} in ${snapraid_config_file_path} not found/writable"
        log_to_email ""
        notify_of_warning "SnapRAID-DAILY: Content File(s) Error"
        clean_up_logfiles
        exit "$error_code"
      fi
    fi
  done < "${snapraid_config_file_path}"
}

###################################################
# LOGGING FUNCTIONS
###################################################
# Log to the Output and the Email (With/Without the Time)
log_to_email() {
  printf '%s\n' "$*" | tee -a "${main_logfile}"
}
log_to_email_time() {
  printf '%s\n' "$(date +%H:%M:%S) : $*" | tee -a "${main_logfile}"
}
log() {
  printf '%s\n' "$*"
}

# Generate the necessary logfiles in /tmp using mktemp
generate_logfiles() {

  # Check to see if one can write to /tmp, try systemd provided $TMPDIR 1st
  TMPDIR="${TMPDIR:-/tmp}"
  if [[ ! -w "${TMPDIR}" ]]; then
    error "${TMPDIR} directory is not writable - Exiting"
  fi

  # Tmp file Prefix - ".txt" added at the end for email attachments
  tmp_file_prefix="snapraid-daily.XXXXX.txt"

  # Generate Logfiles - Export main_logfile to allow hooks to write to it
  main_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  status_command_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  scrub_command_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  sync_command_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  touch_command_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  diff_command_logfile="$( mktemp -t "${tmp_file_prefix}" )"
  export main_logfile

  # Extra Logfiles Required for Inserting Differences in Email Report
  main_logfile_without_diff="$( mktemp -t "${tmp_file_prefix}" )"
  sync_changes_log="$( mktemp -t "${tmp_file_prefix}" )"
  scrub_changes_log="$( mktemp -t "${tmp_file_prefix}" )"
}

##################################################
# SNAPRAID COMMANDS
##################################################
snapraid_status_cmd() {
  # Call Snapraid Status using the "-l" option
  if [[ $quiet_option == "yes" ]]; then
    "${snapraid_binary_path}" -c "${snapraid_config_file_path}" -l "${status_command_logfile}" -qq status &> /dev/null || true
  else
    "${snapraid_binary_path}" -c "${snapraid_config_file_path}" -l "${status_command_logfile}" -qq status || true
  fi
}

snapraid_status_to_email() {
  # Call Snapraid status and pipe the output into the email
  log_to_email "##############################"
  log_to_email "# SnapRAID-DAILY: Array Status"
  log_to_email "##############################"
  log_to_email_time "Current Status of the Array is as below:"
  "${snapraid_binary_path}" -c "${snapraid_config_file_path}" -qq status | tee -a "${main_logfile}" || true
  log_to_email ""
}

# Call Snapraid smart and pipe the output into the email
snapraid_smart_report() {
  local arg="${1:-}"
  if [[ "${arg}" == "non_root" ]]; then
    sudo "${snapraid_binary_path}" -c "${snapraid_config_file_path}" smart | tee -a "${main_logfile}" || true
  else
    "${snapraid_binary_path}" -c "${snapraid_config_file_path}" smart | tee -a "${main_logfile}" || true
  fi
}

# Call Snapraid down to spin down disks
snapraid_spin_down_disks() {
  local arg="${1:-}"
  if [[ "${arg}" == "non_root" ]]; then
    sudo "${snapraid_binary_path}" -c "${snapraid_config_file_path}" down | tee -a "${main_logfile}" || true
  else
    "${snapraid_binary_path}" -c "${snapraid_config_file_path}" down | tee -a "${main_logfile}" || true
  fi
}

# Call snapraid touch to update timestamps. Suppress all output if --quiet option is set
snapraid_touch_cmd() {
  snapraid_touch_args=( -c "${snapraid_config_file_path}" -v -l "${touch_command_logfile}" )
  if [[ $quiet_option == "yes" ]]; then
    snapraid_touch_args+=( -qqqq )
  fi

  # No "|| true" here for touch, as the touch command below requires its return status
  # This is needed as log tags are somewhat limited for the touch operation
  "${snapraid_binary_path}" "${snapraid_touch_args[@]}" touch
}

# Call snapraid diff - Suppress all output if the -q, --quiet option is set
snapraid_diff_cmd() {
  snapraid_diff_args=( -c "${snapraid_config_file_path}" -v -l "${diff_command_logfile}" ) 
  if [[ $quiet_option == "yes" ]]; then
    snapraid_diff_args+=( -qqqq )
  fi
  "${snapraid_binary_path}" "${snapraid_diff_args[@]}" diff || true

  # Get the numbers and exit status from analyzing the command logfile
  number_equal=$( awk -F ":" '/^summary:equal:/ {print $3}' "${diff_command_logfile}")
  number_added=$( awk -F ":" '/^summary:added:/ {print $3}' "${diff_command_logfile}")
  number_removed=$( awk -F ":" '/^summary:removed:/ {print $3}' "${diff_command_logfile}")
  number_updated=$( awk -F ":" '/^summary:updated:/ {print $3}' "${diff_command_logfile}")
  number_moved=$( awk -F ":" '/^summary:moved:/ {print $3}' "${diff_command_logfile}")
  number_copied=$( awk -F ":" '/^summary:copied:/ {print $3}' "${diff_command_logfile}")
  number_relocated=$( awk -F ":" '/^summary:relocated:/ {print $3}' "${diff_command_logfile}")
  number_restored=$( awk -F ":" '/^summary:restored:/ {print $3}' "${diff_command_logfile}")
  diff_exit_status=$( awk -F ":" '/^summary:exit:/ {print $3}' "${diff_command_logfile}")

  # Check if any of the above are undefined, or if the exit status is not expected
  if [[ -z ${number_equal} || -z ${number_added} || -z ${number_removed} || -z ${number_relocated} || \
        -z ${number_updated} || -z ${number_moved} || -z ${number_copied} || \
        -z ${number_copied} || -z ${number_restored} || -z "${diff_exit_status}" ]]; then
    log_to_email_time "Problem with Diff Command - Stopping"
    log_to_email_time "Diff Command Logfile Is attached..."
    log_to_email ""
    run_end_hooks
    notify_of_warning "SnapRAID-DAILY: Diff Warning(s)" "${diff_command_logfile}"
    clean_up_logfiles
    exit $error_code
  elif [[ "${diff_exit_status}" != "diff" && "${diff_exit_status}" != "equal" && \
          "${diff_exit_status}" != "unsynced" ]]; then
    log_to_email_time "Unexpected Exit Status for Diff - Stopping"
    log_to_email_time "It should be either \"diff\", \"equal\" or \"unsynced\""
    log_to_email_time "Diff Command Logfile Is attached..."
    log_to_email ""
    run_end_hooks
    notify_of_warning "SnapRAID-DAILY: Diff Warning(s)" "${diff_command_logfile}"
    clean_up_logfiles
    exit $error_code
  fi    
}

# Call snapraid sync
snapraid_sync_cmd() {
  snapraid_sync_args=( -c "${snapraid_config_file_path}" -v -l "${sync_command_logfile}")

  # Check for force_zero, force_empty, force_uuid, or force_nocopy inputs
  if [[ "${force_zero}" == "yes" ]]; then
    snapraid_sync_args+=( --force-zero )
    log_to_email_time "SYNC WARNING: --force-zero is enabled."
  fi 
  if [[ "${force_empty}" == "yes" ]]; then
    snapraid_sync_args+=( --force-empty )
    log_to_email_time "SYNC WARNING: --force-empty is enabled."
  fi
  if [[ "${force_uuid}" == "yes" ]]; then
    snapraid_sync_args+=( --force-uuid )
    log_to_email_time "SYNC WARNING: --force-uuid is enabled."
  fi

  # Add Pre-Hash Step (On by default), however disable if the force_nocopy is enabled
  if [[ "${sync_pre_hash}" == "yes" ]]; then
    if [[ "${force_nocopy}" == "no" ]]; then
      snapraid_sync_args+=( -h )
    else
      log_to_email_time "SYNC WARNING: Disabling Pre-Hash as force_nocopy is enabled."
    fi
  fi
  if [[ "${force_nocopy}" == "yes" ]]; then
    snapraid_sync_args+=( --force-nocopy )
    log_to_email_time "SYNC WARNING: --force-nocopy is enabled."
  fi
 
  # Suppress all output if the -q, --quiet option is set, then call sync
  if [[ $quiet_option == "yes" ]]; then
    snapraid_sync_args+=( -qqqq )
  fi
  "${snapraid_binary_path}" "${snapraid_sync_args[@]}" sync || true
}

# Call snapraid scrub - suppress output if quiet option is used
snapraid_scrub_cmd() {
  snapraid_scrub_args=( -c "${snapraid_config_file_path}" -v -p "$scrub_percent" -o "$scrub_age" -l "${scrub_command_logfile}" ) 
  if [[ $quiet_option == "yes" ]]; then
    snapraid_scrub_args+=( -qqqq )
  fi
  "${snapraid_binary_path}" "${snapraid_scrub_args[@]}" scrub || true
}

