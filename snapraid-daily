# Function to Parse Input Arguments to the Script - Unset variables 1st
parse_arguments() {

  # Check for valid input arguments
  while (( ${#} )); do
    case "${1}" in

      # Check for Sync Only
      -s|--sync-only)
        sync_only="yes"
      ;;

      # Check for Scrub Only
      -c|--scrub-only)
        scrub_only="yes"
      ;;

      # Check for Override Thresholds
      -o|--override-thresholds)
        override_thresholds="yes"
      ;;

      # Check for Quiet Option
      -q|--quiet)
        quiet_option="yes"
      ;;

      # Check if the default config is overriden, also check if the file is empty or doesn't exist
      -f|--config)
        shift 1
        if (( $# == 0 )); then
          log "ERROR: Specified custom config file, but none given - Exiting"
          print_help
        elif [[ ! -f "${1}" ]]; then
          log "ERROR: Specified custom config file, but given file does not exist - Exiting"
          print_help
        else
          custom_config_file="${1}"
        fi
      ;;

      # Disable Touch
      -d|--disable-touch)
        disable_touch="yes"
      ;;

      # Ignore Script User
      -i|--ignore-user)
        ignore_script_user="yes"
      ;;

      # Check for Help
      -h|--help)
        print_help
      ;;

      # Check for Force Zero
      -fz|--force-zero)
        force_zero_arg="yes"
      ;;

      # Check for Force Empty
      -fe|--force-empty)
        force_empty_arg="yes"
      ;;

      # Check for Force UUID
      -fu|--force-uuid)
        force_uuid_arg="yes"
      ;;

      # Check for Force No-Copy
      -fn|--force-nocopy)
        force_nocopy_arg="yes"
      ;;

      # Check for an Unrecognised Argument
      *)
        log "Invalid Input Argument:" "${1}"
        log ""
        print_help
      ;;
    esac
    shift 1
  done

  # Check if any of the above argument variables were not defined
  if [[ -z "${sync_only}" ]]; then sync_only="no"; fi
  if [[ -z "${scrub_only}" ]]; then scrub_only="no"; fi
  if [[ -z "${override_thresholds}" ]]; then override_thresholds="no"; fi
  if [[ -z "${quiet_option}" ]]; then quiet_option="no"; fi
  if [[ -z "${disable_touch}" ]]; then disable_touch="no"; fi
  if [[ -z "${ignore_script_user}" ]]; then ignore_script_user="no"; fi
  if [[ -z "${force_zero_arg}" ]]; then force_zero_arg="no"; fi
  if [[ -z "${force_empty_arg}" ]]; then force_empty_arg="no"; fi
  if [[ -z "${force_uuid_arg}" ]]; then force_uuid_arg="no"; fi
  if [[ -z "${force_nocopy_arg}" ]]; then force_nocopy_arg="no"; fi

  # Check if --sync-only and --scrub-only were specified at the same time - Exit if so
  if [[ $sync_only == "yes" && $scrub_only == "yes" ]]; then
    log "-s|--sync-only & -c|--scrub-only arguments can't both be specified at the same time - Exiting"
    log ""
    print_help
  fi

  # Check if --override-thresholds and --scrub-only were specified at the same - Warn if so
  if [[ $scrub_only == "yes" && $override_thresholds == "yes" ]]; then
    log "WARNING: -o|--override-thresholds has no effect when using -c|--scrub-only"
  fi
}

